APP_ENV=production
APP_NAME=Unilo
APP_VERSION=0.1.0
HTTP_ADDR=:8080
SERVER_PUBLIC_URL=http://ALI6_HOST_OR_IP:8000
BACKEND_HOST_PORT=8000
POSTGRES_BIND_HOST=0.0.0.0
POSTGRES_PORT=5432
REDIS_BIND_HOST=0.0.0.0
REDIS_PORT=6379
MINIO_BIND_HOST=0.0.0.0
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_USER=unilo
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=unilo
DATABASE_URL=postgres://unilo:replace-with-strong-postgres-password@postgres:5432/unilo?sslmode=disable

REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_DB=0
REDIS_ADDR=redis:6379

MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-strong-minio-secret-key
STORAGE_ACCESS_KEY=replace-with-minio-access-key
STORAGE_SECRET_KEY=replace-with-strong-minio-secret-key
STORAGE_BUCKET=unilo
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=minio:9000
STORAGE_USE_SSL=false
MAX_UPLOAD_BYTES=104857600

SERVICE_SECRET_KEY=replace-with-long-random-service-secret
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=168h

AGENT_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_TIMEOUT=30s
AGENT_MAX_HISTORY_MESSAGES=20
AGENT_MAX_CONTEXT_RESULTS=8

TZ=Asia/Shanghai
