APP_ENV=development
APP_NAME=Unilo
APP_VERSION=0.1.0
HTTP_ADDR=:8080
SERVER_PUBLIC_URL=http://localhost:8080
SERVICE_SECRET_KEY=change-me

POSTGRES_USER=unilo
POSTGRES_PASSWORD=unilo
POSTGRES_DB=unilo
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=8001
POSTGRES_SSLMODE=disable
# DATABASE_URL=postgres://unilo:unilo@127.0.0.1:8001/unilo?sslmode=disable

REDIS_ADDR=127.0.0.1:8002
REDIS_PASSWORD=change-me
REDIS_DB=0

MINIO_ROOT_USER=unilo
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=8003
MINIO_CONSOLE_PORT=8004
STORAGE_ENDPOINT=127.0.0.1:8003
STORAGE_ACCESS_KEY=unilo
STORAGE_SECRET_KEY=change-me-minio
STORAGE_BUCKET=unilo
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false
MAX_UPLOAD_BYTES=104857600

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=168h

AGENT_ENABLED=true
# OPENAI_* is preferred; existing AI_* aliases are also supported.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.deepseek.com
# AI_API_KEY=
# AI_MODEL=deepseek-v4-flash
AGENT_TIMEOUT=30s
AGENT_MAX_HISTORY_MESSAGES=20
AGENT_MAX_CONTEXT_RESULTS=8
